    help="Path to pre-generated prompt pairs JSON.",
)
parser.add_argument(
    "--pair-index",
    type=int,
    default=0,
    help="Which pair to analyze (default: 0, first pair).",
)
parser.add_argument(
    "--n-pairs",
    type=int,
    default=1,
    help="How many pairs to analyze (starting from --pair-index).",
)
parser.add_argument(
    "--layers",
    type=int,
    nargs="+",
    default=None,
    help="Layer indices to test (default: every 4th layer 0-63). Example: 0 5 10 15",
)
parser.add_argument(
    "--no-plot",
    action="store_true",
    help="Skip heatmap visualization (still save .npz data).",
)

args = parser.parse_args()

# Set defaults
if args.layers is None:
    LAYERS_TO_TEST = list(range(0, 64, 4))
else:
    LAYERS_TO_TEST = args.layers

TARGET_TOKEN_INDICES: List[int] = args.target_indices or []

print("=" * 80)
print("SIMPLE CAUSAL TRACING via ACTIVATION PATCHING")
